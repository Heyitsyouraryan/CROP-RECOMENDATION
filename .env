# ─────────────────────────────────────────────
#  IBM watsonx.ai – Crop Recommendation System
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# IBM Cloud API Key (IAM)
IBM_API_KEY=
# IBM watsonx.ai deployment endpoint (REST scoring URL)
# Example: https://us-south.ml.cloud.ibm.com/ml/v4/deployments/<deployment_id>/predictions?version=2021-05-01
DEPLOYMENT_URL=

# IBM Cloud IAM token endpoint (do not change unless using a different region)
IAM_TOKEN_URL=

# watsonx.ai project or space ID (shown in your deployment details)
WATSONX_PROJECT_ID=
